{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"skipLibCheck": true,
		"strict": true,
		"experimentalDecorators": true,
		"strictFunctionTypes": false,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"allowJs": true,
		"sourceMap": true,
		"importHelpers": true,
		"resolveJsonModule": true,
		"useDefineForClassFields": false,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"ignoreDeprecations": "6.0",
		"jsx": "preserve",
		"lib": ["esnext", "dom", "dom.iterable", "scripthost"],
		"types": [
			"node",
			"nw.js",
			"stripe-v3",
			"grecaptcha",
			"google-publisher-tag",
			"google_interactive_media_ads_types",
			"dom-mediacapture-transform",
			"dom-webcodecs"
		],
		"paths": {
			"~img/*": ["./src/_img/*"],
			"~app/*": ["./src/app/*"],
			"~auth/*": ["./src/auth/*"],
			"~checkout/*": ["./src/checkout/*"],
			"~claim/*": ["./src/claim/*"],
			"~client/*": ["./src/client/*"],
			"~common/*": ["./src/_common/*"],
			"~editor/*": ["./src/editor/*"],
			"~gameserver/*": ["./src/gameserver/*"],
			"~lib/*": ["./src/lib/*"],
			"~site-editor/*": ["./src/site-editor/*"],
			"~styles/*": ["./src/_styles/*"],
			"~utils/*": ["./src/utils/*"],
			"~widget-package/*": ["./src/widget-package/*"],
			"~z/*": ["./src/z/*"],
			"~typings/*": ["./typings/*"]
		}
	},
	"exclude": ["build", "node_modules", ".cache"],
	"vueCompilerOptions": {
		"strictTemplates": true
	}
}
