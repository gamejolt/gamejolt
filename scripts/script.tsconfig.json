{
	"compilerOptions": {
		"baseUrl": "../",
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"strictNullChecks": true,
		"resolveJsonModule": true,
		"ignoreDeprecations": "6.0"
	}
}
